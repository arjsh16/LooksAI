# ── App ────────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=false

# ── CORS (comma-separated) ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://arjsh16.github.io

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://looksai:looksai@localhost:5432/looksai

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Mistral ────────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_MODEL=mistral-small-latest

# ── File storage ───────────────────────────────────────────────────────────────
UPLOAD_DIR=/tmp/looksai_uploads
MAX_UPLOAD_SIZE=10485760

# ── ML model path (optional — heuristics used if not present) ──────────────────
EFFICIENTNET_MODEL_PATH=models/skin_efficientnet.pth
